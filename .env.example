# Backend API (server/) — LLM (Google Gemma 3 27B par défaut, ou OpenAI/Ollama)
# Copier en .env et remplir. Serveur : npm run dev:server (racine) ou cd server && npm start

# --- Option 1 : Google AI — Gemma 3 27B (recommandé) ---
# 1. Créer une clé : https://aistudio.google.com/app/apikey
# 2. Dans .env :
# GOOGLE_API_KEY=AIza...

# --- Option 2 : Ollama (gratuit, local, pas de clé) ---
# OPENAI_API_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2
# (pas de GOOGLE_API_KEY, pas de OPENAI_API_KEY)

# --- Option 3 : Groq (gratuit, cloud) ---
# OPENAI_API_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.1-8b-instant

# --- Option 4 : OpenAI (payant) ---
# OPENAI_API_KEY=sk-...
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Port du backend (défaut 3001)
# PORT=3001
