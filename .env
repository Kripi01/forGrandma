# Backend API (server/) — LLM via Ollama (local, gratuit)
# Lancer Ollama et le modèle : ollama run gemma3:27b

# Ollama (pas de clé nécessaire)
OPENAI_API_URL=http://localhost:11434/v1
OPENAI_MODEL=gemma3:27b

# Ancienne clé OpenAI (décommenter pour repasser sur OpenAI)
# OPENAI_API_KEY=sk-...

# Port du backend (défaut 3001)
# PORT=3001
